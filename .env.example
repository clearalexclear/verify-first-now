# VerifyFirst environment variables
# Copy to .env for local/server-side testing. Never commit real secrets.

###############################################################################
# Required now for Supabase
###############################################################################
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

###############################################################################
# Required for AI investigation
###############################################################################
# Used for document extraction, entity-resolution assistance, finding synthesis,
# and report narrative generation. Keep server-side only.
LOVABLE_API_KEY=replace-with-lovable-ai-gateway-key

###############################################################################
# Required for web research
###############################################################################
# Firecrawl is web intelligence only. It cannot independently verify corporate
# registration, shipment history, certificate validity or litigation.
FIRECRAWL_API_KEY=replace-with-firecrawl-key

###############################################################################
# Required for email/report delivery
###############################################################################
PUBLIC_SITE_URL=http://localhost:3000
VITE_PUBLIC_SITE_URL=http://localhost:3000
RESEND_API_KEY=replace-with-resend-key
REPORT_FROM_EMAIL=VerifyFirst <reports@example.com>

###############################################################################
# Test-only investigation trigger
###############################################################################
# Required to run `npm run investigation:test -- --case-id <uuid>` or
# `npm run investigation:test -- --order-id <uuid>`.
# The trigger is CLI/server-side only and is not exposed to public browser routes.
VERIFYFIRST_ENABLE_TEST_INVESTIGATION=false
# Production requires this second explicit flag as well. Leave false unless doing
# a controlled manual production test.
VERIFYFIRST_ALLOW_PRODUCTION_TEST_INVESTIGATION=false

###############################################################################
# Required later for paid data connectors
###############################################################################
# Keep blank until licensed credentials and storage permissions are supplied.
QCC_API_KEY=
IMPORTGENIUS_API_KEY=
IAF_CERTSEARCH_API_KEY=
OPENSANCTIONS_API_KEY=

###############################################################################
# Required later for Stripe
###############################################################################
# Stripe is intentionally not implemented/enabled in this phase.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRIORITY=
STRIPE_PRICE_ONSITE=
